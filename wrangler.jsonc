  //     /mazareal-kids-game/  -> mazareal-kids-game/index.html
  // ※ name は Cloudflare のプロジェクト名と一致させること。
  "name": "test",
  "compatibility_date": "2025-06-01",
  "assets": {
    "directory": "./"
  }
}
